{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sentrux Experiment Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "experiment_id",
    "title",
    "workstream",
    "status",
    "cycle_id",
    "program_id",
    "phase_id",
    "owner_doc",
    "decision_question",
    "hypothesis",
    "primary_metrics",
    "secondary_metrics",
    "variants",
    "repo_runs",
    "exit_bar"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "experiment_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "workstream": {
      "enum": [
        "default_lane",
        "structural_pressure",
        "obligation_breadth",
        "treatment_baseline",
        "bounded_llm_adjudication"
      ]
    },
    "status": {
      "enum": ["planned", "in_progress", "completed", "blocked"]
    },
    "cycle_id": {
      "type": "string",
      "minLength": 1
    },
    "program_id": {
      "type": "string",
      "minLength": 1
    },
    "phase_id": {
      "type": "string",
      "minLength": 1
    },
    "owner_doc": {
      "type": "string",
      "minLength": 1
    },
    "decision_question": {
      "type": "string",
      "minLength": 1
    },
    "hypothesis": {
      "type": "string",
      "minLength": 1
    },
    "primary_metrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "secondary_metrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "variants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/variant"
      }
    },
    "repo_runs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repoRun"
      }
    },
    "exit_bar": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["outcome"],
      "properties": {
        "outcome": {
          "enum": [
            "promote",
            "keep_experimental",
            "demote",
            "discard",
            "expand_follow_up"
          ]
        },
        "winner_variant_id": {
          "type": ["string", "null"]
        },
        "loser_variant_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decided_at": {
          "type": ["string", "null"]
        },
        "evidence_summary": {
          "type": ["string", "null"]
        },
        "policy_change": {
          "type": ["string", "null"]
        }
      }
    }
  },
  "$defs": {
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variant_id", "name", "description"],
      "properties": {
        "variant_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["active", "screening", "shortlisted", "selected", "rejected"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "policy_delta": {
          "type": ["string", "null"]
        }
      }
    },
    "repoRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "repo_id", "variant_id", "manifest", "output_dir"],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "repo_id": {
          "type": "string",
          "minLength": 1
        },
        "variant_id": {
          "type": "string",
          "minLength": 1
        },
        "execution_mode": {
          "enum": ["repo_calibration_loop", "manual_review", "policy_branch"]
        },
        "manifest": {
          "type": "string",
          "minLength": 1
        },
        "output_dir": {
          "type": "string",
          "minLength": 1
        },
        "flags": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "skip_live": {
              "type": "boolean"
            },
            "skip_replay": {
              "type": "boolean"
            },
            "skip_review": {
              "type": "boolean"
            },
            "skip_scorecard": {
              "type": "boolean"
            },
            "skip_backlog": {
              "type": "boolean"
            }
          }
        },
        "notes": {
          "type": ["string", "null"]
        },
        "artifact_expectations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
