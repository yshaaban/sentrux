  "phase_id": "phase_6_large_file_admissibility",
  "owner_doc": "../../experiment-program.md",
  "decision_question": "Should large_file remain eligible for the default lane at all, and if so under what exact restrictions?",
  "hypothesis": "Large-file pressure is simple enough and often useful enough to keep testing as a default-lane candidate, but it should stay there only if measured repair value survives across the fixed repo matrix without crowding out more causal leads.",
  "primary_metrics": [
    "top_action_help_rate",
    "top_action_follow_rate",
    "task_success_rate",
    "patch_expansion_rate",
    "intervention_net_value_score"
  ],
  "secondary_metrics": [
    "ranking_miss_count",
    "reviewed_precision",
    "reviewer_disagreement_rate",
    "demotion_candidate_count"
  ],
  "control_variant_id": "current_policy",
  "repo_scope": ["sentrux", "parallel-code", "one-tool"],
  "stages": [
    {
      "stage_id": "screen",
      "title": "Screen large_file admissibility variants on the fixed three-repo matrix",
      "status": "in_progress",
      "exit_bar": [
        "Collect evidence for every admissibility rule on sentrux, parallel-code, and one-tool.",
        "Shortlist the strongest keep, guardrail, and demotion candidates."
      ],
      "notes": "The registry is active but fresh screening evidence is still missing."
    },
    {
      "stage_id": "confirm",
      "title": "Confirm the strongest large_file rule against current_policy",
      "status": "planned",
      "exit_bar": [
        "Re-run the shortlisted large_file rules on the same fixed repo/task battery.",
        "Reject any rule that improves follow without improving help or that increases patch expansion enough to erase the gain."
      ],
      "notes": "Blocked on stage-one evidence."
    },
    {
      "stage_id": "decide",
      "title": "Record the keep, constrain, or demote decision for large_file",
      "status": "planned",
      "exit_bar": [
        "Write a decision record that names whether large_file stays, stays with guardrails, or demotes to supporting context.",
        "Update the promotion ledger with the final admissibility rule."
      ],
      "notes": "Blocked on screening and confirmation."
    }
  ],
