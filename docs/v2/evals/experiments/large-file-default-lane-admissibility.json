    },
    {
      "variant_id": "supporting_only",
      "name": "Supporting only",
      "status": "screening",
      "description": "Keep large_file visible as context but never let it occupy a primary slot.",
      "policy_delta": "Demote large_file to supporting evidence only.",
      "policy_override": {
