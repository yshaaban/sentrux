{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Codex Session Batch Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repo_root", "tasks"],
  "properties": {
    "schema_version": { "const": 1 },
    "batch_id": { "type": "string" },
    "cohort_id": { "type": "string" },
    "repo_root": { "type": "string", "minLength": 1 },
    "repo_label": { "type": "string" },
    "rules_source": { "type": "string" },
    "analysis_mode": { "enum": ["working_tree", "head_clone"] },
    "model": { "type": ["string", "null"] },
    "timeout_ms": { "type": "integer", "minimum": 1 },
    "idle_timeout_ms": { "type": "integer", "minimum": 1 },
    "poll_ms": { "type": "integer", "minimum": 1 },
    "codex_bin": { "type": "string" },
    "expected_signal_kinds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "task_label"],
        "properties": {
          "task_id": { "type": "string", "minLength": 1 },
          "task_label": { "type": "string", "minLength": 1 },
          "prompt": { "type": "string" },
          "prompt_file": { "type": "string" },
          "tags": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "expected_signal_kinds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expected_fix_surface": { "type": "string" },
          "experiment_arm": {
            "type": "string",
            "enum": [
              "no_intervention",
              "no-intervention",
              "report_only",
              "report-only",
              "fix_this_first",
              "fix-first",
              "stop_and_refactor",
              "stop-and-refactor",
              "baseline",
              "baseline/no-intervention",
              "directive_fix_first",
              "directive_stop_and_refactor"
            ]
          },
          "session_goal": { "type": "string" },
          "success_criteria": { "type": "string" },
          "timeout_ms": { "type": "integer", "minimum": 1 },
          "idle_timeout_ms": { "type": "integer", "minimum": 1 }
        },
        "oneOf": [
          { "required": ["prompt"] },
          { "required": ["prompt_file"] }
        ]
      }
    }
  }
}
